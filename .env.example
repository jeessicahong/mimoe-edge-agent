# ─────────────────────────────────────────────────────────────────────────────
# mimoe-edge-agent environment configuration
#
# 1. Copy this file to .env  (cp .env.example .env)
# 2. Open mimOE Studio → Model View → API button
# 3. Fill in the values below from what the API panel shows
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the local mimOE inference endpoint.
# Should end with /v1 (or whatever path the API button shows).
# Example: http://localhost:8080/v1
MIMOE_BASE_URL=http://localhost:8080/v1

# Model identifier as shown in mimOE Studio.
# This is passed as the `model` field in every chat completion request.
# Example: SmolLM2
MIMOE_MODEL=SmolLM2

# API key — mimOE's local endpoint typically does not enforce authentication,
# but the OpenAI client requires a non-empty value. Leave as-is unless your
# Studio setup requires a specific key.
MIMOE_API_KEY=not-required

LOG_LEVEL=INFO # or use DEBUG for development purposes.
